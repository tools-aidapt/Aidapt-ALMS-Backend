PORT=4000
NODE_ENV=development

# Supabase / Postgres -------------------------------------------------------
# Postgres connection string (Supabase: Project Settings > Database > Connection string > URI)
DATABASE_URL=

# Supabase project API (Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional/legacy — tokens are verified via the project JWKS derived from SUPABASE_URL
SUPABASE_JWT_SECRET=

# Geofence default (metres) — used when OfficeConfig row omits RadiusMeters
OFFICE_GEOFENCE_DEFAULT_RADIUS_M=50

# Email — the backend POSTs a JSON payload to an n8n webhook; n8n sends the email.
N8N_EMAIL_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=
EMAIL_FROM=alms@aidapt.co
# Dedicated webhook for the password-reset OTP email (falls back to N8N_EMAIL_WEBHOOK_URL)
N8N_PASSWORD_RESET_WEBHOOK_URL=

# Public base URL used to build email links
APP_BASE_URL=http://localhost:4000

# Set when deployed behind a proxy/load balancer so client IPs (for rate
# limiting) are read from X-Forwarded-For. e.g. "1" (first hop) or "true".
TRUST_PROXY=

# On App Runner set ENABLE_CRON=false and trigger jobs externally (n8n/pg_cron).
ENABLE_CRON=

# Shared secret to authenticate machine-triggered jobs (sent as the
# X-Job-Secret header to POST /api/jobs/mark-absent). Generate a random value.
JOBS_SECRET=

# Airtable (only needed to run scripts/migrate-from-airtable.js once)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
